# Connection string SQL Server
# IMPORTANTE: Modifica con le tue credenziali reali
SQL_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=TestDB;UID=sa;PWD=YourPassword

# Limiti di sicurezza
MAX_ROWS=100
QUERY_TIMEOUT=30

# Pool di connessioni
POOL_SIZE=5
POOL_TIMEOUT=30

# Tabelle da escludere (separate da virgola, supporta wildcards)
# Esempi: sys_*, *_audit, internal_*
BLACKLIST_TABLES=sys_logs,audit_trail,*_temp

# Schema permessi (opzionale, vuoto = tutti)
# Se specificato, solo questi schemi saranno accessibili
ALLOWED_SCHEMAS=dbo,custom

# Logging
LOG_LEVEL=INFO
