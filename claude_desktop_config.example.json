{
  "_comment": "Due modalità di configurazione: argomenti CLI (consigliato) oppure variabili d'ambiente.",

  "mcpServers": {

    "sqlserver-args": {
      "_comment": "MODALITÀ CONSIGLIATA — tutti i parametri passati come argomenti dalla console di Claude",
      "command": "python",
      "args": [
        "-m", "mcp_sqlserver.server",
        "--connection-string", "Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=TestDB;UID=sa;PWD=YourPassword",
        "--max-rows", "100",
        "--query-timeout", "30",
        "--pool-size", "5",
        "--pool-timeout", "30",
        "--blacklist-tables", "sys_logs,*_audit,*_temp",
        "--allowed-schemas", "",
        "--log-level", "INFO"
      ]
    },

    "sqlserver-env": {
      "_comment": "MODALITÀ ALTERNATIVA — parametri passati come variabili d'ambiente (senza file .env)",
      "command": "python",
      "args": ["-m", "mcp_sqlserver.server"],
      "env": {
        "SQL_CONNECTION_STRING": "Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=TestDB;UID=sa;PWD=YourPassword",
        "MAX_ROWS": "100",
        "QUERY_TIMEOUT": "30",
        "POOL_SIZE": "5",
        "POOL_TIMEOUT": "30",
        "BLACKLIST_TABLES": "sys_logs,*_audit,*_temp",
        "ALLOWED_SCHEMAS": "",
        "LOG_LEVEL": "INFO"
      }
    }

  }
}
